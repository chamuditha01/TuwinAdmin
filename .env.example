# --- Local dev only ---
# Uncomment/change if port 3000 is already used by another project.
# PORT=3010
# BROWSER=none

# --- Google Sheet ---
# The ID from the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEET_ID=1sY7_eNfVYkKDoS3SXm1ft2luVwKsN59orsIjehfV9Xs

# Service account used ONLY for writes (add/edit/delete). Reads use the
# public export URL, so the sheet must stay shared as "Anyone with the link
# can view". Share the sheet with the service account's email as Editor.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key from the downloaded JSON key file, keeping the \n sequences literal.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# --- Cloudinary ---
# Used server-side to delete images from Cloudinary when they're removed from the gallery.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Used client-side (browser) for direct unsigned uploads. Must be prefixed
# with REACT_APP_ to be exposed to the React app by Create React App.
REACT_APP_CLOUDINARY_CLOUD_NAME=your-cloud-name
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
